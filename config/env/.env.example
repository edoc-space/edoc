APP_ENV=dev
APP_DEBUG=1
APP_URL=https://domain.local
APP_KEY=
APP_INFLECTOR_LANG=en
APP_ADMIN_HOST=
APP_ADMIN_PREFIX=/admin

APP_DB_MAIN_DSN="mariadb://app:app@mariadb:3306/app"
APP_DB_SEARCH_DSN="postgres://app:app@postgres:5432/app"
APP_DB_MIGRATIONS_BASE="database/migrations"

APP_STORAGE_DISK=local
APP_STORAGE_URL=/storage
APP_DOCUMENTATION_CACHE=1
APP_DOCUMENTATION_CACHE_TTL=86400
APP_PROFILER=1

APP_AUTH_PROVIDER=database
APP_AUTH_CONNECTION=default
APP_AUTH_USERS_TABLE=users
APP_AUTH_SESSION_KEY=auth.user_id
APP_AUTH_SESSION_HASH_KEY=
APP_AUTH_USER_HASH_KEY=password_hash
APP_AUTH_REMEMBER_COOKIE=remember_token
APP_AUTH_REMEMBER_CONNECTION=default
APP_AUTH_REMEMBER_TABLE=user_tokens
APP_AUTH_REMEMBER_PATH=/
APP_AUTH_REMEMBER_DOMAIN=
APP_AUTH_REMEMBER_SECURE=always
APP_AUTH_REMEMBER_HTTP_ONLY=1
APP_AUTH_REMEMBER_SAME_SITE=Lax
APP_AUTH_REMEMBER_MAX_AGE=2592000
APP_AUTH_REMEMBER_MISMATCH_POLICY=revoke_token
APP_AUTHORIZATION_CONNECTION=default
APP_ADMIN_PERMISSION=admin.access
APP_ADMIN_DENIED_MODE=not_found
APP_ADMIN_REDIRECT_TO=/login

VITE_DEV_SERVER=https://vite.domain.local
VITE_SSR_URL=
VITE_SSR_ENTRY=resources/js/ssr.tsx
VITE_SSR_TIMEOUT=2.0
INERTIA_VERSION=
INERTIA_SSR=0

APP_SESSION_NAME=psb_session
APP_SESSION_DRIVER=native
APP_SESSION_CONNECTION=default
APP_SESSION_TABLE=sessions
APP_SESSION_LIFETIME=0
APP_SESSION_PATH=/
APP_SESSION_DOMAIN=
APP_SESSION_SECURE=always
APP_SESSION_HTTP_ONLY=1
APP_SESSION_SAME_SITE=Lax
APP_SESSION_STRICT=1
APP_SESSION_ONLY_COOKIES=1
APP_SESSION_COOKIES=1
APP_SESSION_GC_MAX_LIFETIME=

TEST_DB_CONNECTIONS=default
TEST_DB_RELOAD=0
TEST_DB_RELOAD_MODE=dump
TEST_DB_SUFFIX=_autotests
TEST_DB_KEEP_DUMPS=0
